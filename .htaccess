# MMSAR — single preferred origin: https://mmsar.au/
# All host/scheme variants 301 → https://mmsar.au/ (path + query preserved)

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Any host other than apex mmsar.au, OR non-HTTPS → preferred origin
  RewriteCond %{HTTP_HOST} !^mmsar\.au$ [NC,OR]
  RewriteCond %{HTTPS} !=on
  RewriteRule ^(.*)$ https://mmsar.au/$1 [R=301,L,QSA]
</IfModule>

<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

Options -Indexes
